#!/usr/bin/env python3
import argparse
import datetime as dt
import json
import os
import re
import sys
import urllib.error
import urllib.request

VERSION = "1.0.0"


def load_env_file():
    env_path = os.path.join(os.path.dirname(os.path.abspath(__file__)), ".env")
    if not os.path.exists(env_path):
        return
    try:
        with open(env_path, "r", encoding="utf-8") as handle:
            for raw_line in handle:
                line = raw_line.strip()
                if not line or line.startswith("#") or "=" not in line:
                    continue
                key, value = line.split("=", 1)
                key = key.strip()
                value = value.strip().strip('"').strip("'")
                if key and key not in os.environ:
                    os.environ[key] = value
    except OSError as exc:
        fail("env_error", "could not read .env file", {"error": str(exc)})


def now_iso():
    return dt.datetime.now(dt.timezone.utc).replace(microsecond=0).isoformat().replace("+00:00", "Z")


def fail(code, message, details=None, exit_code=1):
    payload = {
        "ok": False,
        "error": {
            "code": code,
            "message": message,
            "details": details or {},
        },
    }
    print(json.dumps(payload, ensure_ascii=False, sort_keys=True), file=sys.stderr)
    raise SystemExit(exit_code)


def read_stdin_json(max_bytes):
    raw = sys.stdin.buffer.read(max_bytes + 1)
    if not raw:
        fail("invalid_input", "stdin is empty")
    if len(raw) > max_bytes:
        fail("invalid_input", "stdin exceeds --max-input-bytes", {"max_input_bytes": max_bytes})
    try:
        return json.loads(raw.decode("utf-8"))
    except UnicodeDecodeError as exc:
        fail("invalid_input", "stdin must be UTF-8", {"error": str(exc)})
    except json.JSONDecodeError as exc:
        fail("invalid_json", "stdin must be valid JSON", {"error": str(exc)})


def validate_fetch_payload(payload):
    if not isinstance(payload, dict):
        fail("invalid_input", "input JSON must be an object")
    if payload.get("ok") is not True or payload.get("source") != "repo-fetch":
        fail("invalid_input", "input must be successful repo-fetch output")
    mode = payload.get("mode", "repository")
    if mode == "repository" and not isinstance(payload.get("repository"), dict):
        fail("invalid_input", "repository input missing repository object")
    if mode == "search" and not isinstance(payload.get("search"), dict):
        fail("invalid_input", "search input missing search object")
    if mode not in {"repository", "search"}:
        fail("invalid_input", "unsupported repo-fetch mode", {"mode": mode})


def build_prompt(fetch_payload):
    compact_payload = json.dumps(fetch_payload, ensure_ascii=False, sort_keys=True)
    return f"""
Analyze this GitHub project investigation snapshot. It may contain one concrete repository or GitHub repository search results.

Return exactly one JSON object with this schema and no markdown:
{{
  "health_score": 0,
  "summary": "one paragraph",
  "signals": [
    {{"name": "activity|maintenance|community|risk|momentum", "status": "good|watch|poor", "detail": "short evidence-based detail"}}
  ],
  "risks": [
    {{"severity": "low|medium|high", "title": "short title", "detail": "evidence-based detail"}}
  ],
  "recommendations": [
    {{"priority": "low|medium|high", "action": "specific action", "reason": "why it matters"}}
  ],
  "investment_notes": {{
    "fit": "avoid|watchlist|promising|strong",
    "rationale": "short rationale",
    "diligence_questions": ["question"]
  }}
}}

Use only the evidence in this JSON. If the input is search results, compare the most relevant repositories and identify which projects deserve deeper inspection. If optional issues or commits are absent, say so as a limitation.

GitHub data:
{compact_payload}
""".strip()


def build_messages_url(base_url):
    base = base_url.rstrip("/")
    if base.endswith("/v1/messages"):
        return base
    return f"{base}/v1/messages"


def call_llm(auth_token, base_url, model, prompt, timeout):
    body = {
        "model": model,
        "max_tokens": 2000,
        "temperature": 0,
        "system": "You are a repository health analyst. Return strict JSON only.",
        "messages": [{"role": "user", "content": prompt}],
    }
    request = urllib.request.Request(
        build_messages_url(base_url),
        data=json.dumps(body).encode("utf-8"),
        headers={
            "Authorization": f"Bearer {auth_token}",
            "anthropic-version": "2023-06-01",
            "content-type": "application/json",
            "x-api-key": auth_token,
            "user-agent": "repo-health-skill/repo-analyze",
        },
        method="POST",
    )
    try:
        with urllib.request.urlopen(request, timeout=timeout) as response:
            charset = response.headers.get_content_charset() or "utf-8"
            return json.loads(response.read().decode(charset))
    except urllib.error.HTTPError as exc:
        body = exc.read().decode("utf-8", errors="replace")
        message = body
        try:
            parsed = json.loads(body)
            message = parsed.get("error", {}).get("message", body)
        except json.JSONDecodeError:
            pass
        fail("llm_http_error", "LLM API request failed", {"status": exc.code, "message": message})
    except urllib.error.URLError as exc:
        fail("network_error", "LLM API request failed", {"reason": str(exc.reason)})
    except json.JSONDecodeError as exc:
        fail("invalid_response", "LLM API returned invalid JSON", {"error": str(exc)})


def extract_text(message):
    if isinstance(message.get("choices"), list) and message["choices"]:
        choice_message = message["choices"][0].get("message") or {}
        content = choice_message.get("content")
        if isinstance(content, str) and content.strip():
            return content.strip()

    parts = []
    for item in message.get("content", []):
        if isinstance(item, dict) and item.get("type") == "text":
            parts.append(item.get("text", ""))
    text = "\n".join(parts).strip()
    if not text:
        fail("invalid_response", "LLM response did not contain text")
    return text


def parse_analysis(text):
    try:
        return json.loads(text)
    except json.JSONDecodeError:
        match = re.search(r"\{.*\}", text, flags=re.DOTALL)
        if not match:
            fail("invalid_response", "Claude response did not contain a JSON object")
        try:
            return json.loads(match.group(0))
        except json.JSONDecodeError as exc:
            fail("invalid_response", "Claude response JSON could not be parsed", {"error": str(exc)})


def validate_analysis(analysis):
    if not isinstance(analysis, dict):
        fail("invalid_response", "analysis must be a JSON object")
    required = ["health_score", "summary", "signals", "risks", "recommendations", "investment_notes"]
    missing = [key for key in required if key not in analysis]
    if missing:
        fail("invalid_response", "analysis missing required keys", {"missing": missing})
    score = analysis.get("health_score")
    if not isinstance(score, (int, float)) or score < 0 or score > 100:
        fail("invalid_response", "health_score must be a number between 0 and 100", {"health_score": score})
    return analysis


def main():
    load_env_file()

    default_model = (
        os.environ.get("ANTHROPIC_DEFAULT_HAIKU_MODEL")
        or os.environ.get("ANTHROPIC_MODEL")
        or os.environ.get("CLAUDE_MODEL")
        or "glm-5.1"
    )
    parser = argparse.ArgumentParser(description="Analyze repo-fetch JSON with an Anthropic-compatible LLM and emit structured JSON.")
    parser.add_argument("--model", default=default_model, help="LLM model name. Default: env model or glm-5.1.")
    parser.add_argument("--base-url", default=os.environ.get("ANTHROPIC_BASE_URL", "https://api.anthropic.com"), help="Anthropic-compatible base URL.")
    parser.add_argument("--timeout", type=int, default=60, help="LLM API timeout in seconds. Default: 60.")
    parser.add_argument("--max-input-bytes", type=int, default=200000, help="Maximum stdin size. Default: 200000.")
    args = parser.parse_args()

    if args.timeout < 1:
        fail("invalid_arguments", "--timeout must be at least 1", {"timeout": args.timeout})
    if args.max_input_bytes < 1:
        fail("invalid_arguments", "--max-input-bytes must be at least 1", {"max_input_bytes": args.max_input_bytes})

    auth_token = os.environ.get("ANTHROPIC_AUTH_TOKEN") or os.environ.get("ANTHROPIC_API_KEY")
    if not auth_token:
        fail("missing_environment", "ANTHROPIC_AUTH_TOKEN or ANTHROPIC_API_KEY is required")

    fetch_payload = read_stdin_json(args.max_input_bytes)
    validate_fetch_payload(fetch_payload)
    prompt = build_prompt(fetch_payload)
    message = call_llm(auth_token, args.base_url, args.model, prompt, args.timeout)
    analysis = validate_analysis(parse_analysis(extract_text(message)))

    repo = fetch_payload.get("repository", {})
    search = fetch_payload.get("search", {})
    subject = repo.get("full_name") or f"github search: {search.get('query')}"
    payload = {
        "ok": True,
        "source": "repo-analyze",
        "version": VERSION,
        "analyzed_at": now_iso(),
        "model": args.model,
        "provider": "anthropic-compatible",
        "input": {
            "repository_full_name": subject,
            "mode": fetch_payload.get("mode", "repository"),
            "fetched_at": fetch_payload.get("fetched_at"),
            "included": sorted((fetch_payload.get("data") or {}).keys()),
        },
        "analysis": analysis,
    }
    print(json.dumps(payload, ensure_ascii=False, sort_keys=True))


if __name__ == "__main__":
    main()
