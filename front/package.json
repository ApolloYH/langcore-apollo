{
  "name": "langcore-front",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "rag/apps/*",
    "rag/packages/*"
  ],
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:front": "next dev --port ${FRONT_PORT:-3000}",
    "dev:rag": "npm --workspace @devscope/api run dev",
    "build": "next build",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "start": "next start --port 3000",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^0.554.0",
    "next": "15.5.19",
    "pg": "^8.21.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.31.10",
    "playwright": "^1.60.0",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "postcss": "^8.5.10"
  },
  "engines": {
    "node": ">=20"
  },
  "optionalDependencies": {
    "@next/swc-darwin-arm64": "^15.5.19"
  }
}
